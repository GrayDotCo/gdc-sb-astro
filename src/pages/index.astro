        <img src="https://assets.thegray.company/f/1016570/900x600/a4f1b09d2a/blog_ai-crawling_00_preview.png" width="480" height="280" alt="How to do an AI Crawling Audit" />
      </div>
    </div>
  </section>


  <section class="no-h-padding testimonials">
