        </div>      
        <div class="card-testimonial">
          <img src={transformImageSrc("https://assets.thegray.company/f/1016570/120x120/9b1e90b1f2/naresh-venkat.jpeg")} alt="Naresh Venkat, Co-Founder, Osmos" width="120" height="120" />
