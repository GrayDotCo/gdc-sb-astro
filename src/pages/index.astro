---
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { transformImageSrc } from "../utils/imageUtils";

const sbApi = useStoryblokApi();
const { data } = await sbApi.get("cdn/stories/home", {
  version: "draft",
  resolve_links: "url",
  resolve_relations: ['featured_blogs.blogs'],
});

const story = data.story;
const storySEO = {
  title: story.content.page_title,
  description: story.content.meta_description,
  ogImage: story.content.og_image?.filename,
  metaRobots: story.content.noindex
};

const logoCarousel = story.content.body.find(blok => blok.component === 'carousel');
const featuredBlogs = story.content.body.find(blok => blok.component === 'featured_blogs');

---

<BaseLayout
  title={storySEO.title}
  description={storySEO.description}
  ogImage={storySEO.ogImage}
  metaRobots={storySEO.metaRobots}
>

  <section class="hero">
    <div class="ipu">
      <div>
        <h1>Connecting the Dots Between AI and Search</h1>
        <p>Drive consistent growth in the face of constant flux, while intelligently optimizing for an increasingly AI future. </p>
        <a href="/contact" class="btnPrimary">Connect with an expert</a>
      </div>
      <div class="img-hero img-hero-home">
        <img src="img/illustrations/img_home-hero.png" width="712" height="512" alt="" />
      </div>
    </div>
  </section>


  <section class="align-center">
    <div class="ipu">
      <div>
        <h2>Who said SEO is dead?</h2>
        <p>Search isn’t dying, it’s diversifying. <br/>Users are turning to different sites in different situations for different answers. <br/>Today, LLMs like Claude, forums like Reddit, and social apps like TikTok are “search engines” too. <br/>In a time where SEO calls for connecting the dots, we bring clarity to a complex ecosystem — highlighting the path to resilient, fuutre-ready growth.</p>
        <a href="/approach" class="btnPrimary">SEE OUR APPROACH</a>      
      </div>
    </div>
  </section>


  <section class="bg-grey inner-section">
    <div class="ipu">
      <div>
        <p class="prehead">PER_PROJECT SOLUTIONS</p>
        <h2>Answers, insights, & actionable strategy when you need it most</h2>
        <p>Need answers but not an agency? Our solutions are fine-tuned to quickly address common pain points with rapid recommendations, clear timelines, and no awkward goodbyes.</p>
      </div>

      <div class="flex-wrap wrap-three services li-bold">
        <div class="col-flex-row">
          <img class="illustration" src="https://assets.thegray.company/f/1016570/80x80/88c54c320a/ic_ideation.svg" alt="" width="64" height="64" />
          <div>
            <h3>Analysis</h3>
            <ul class="services-list">
              <li><a href="/services/opportunity-analysis">OPPORTUNITY ANALYSIS ></a></li>
              <li><a href="/services/paid-search">COMPETITIVE ANALYSIS ></a></li>
              <li><a href="/services/competitive-analysis">TRAFFIC LOSS INVESTIGATIONS ></a></li>
            </ul>
          </div>
        </div>

        <div class="col-flex-row">
          <img class="illustration" src="img/icons/ic_category-marketing_tech.svg" alt="" width="64"
            height="64" />
          <div>
            <h3>Audits</h3>
            <ul class="services-list">
              <li>CONTENT AUDITS</li>
              <li>TECH SEO AUDITS</li>
              <li><a href="/services/ai-audits">AI AUDITS ></a></li>
              <li>JS RENDERING AUDITS</li>
            </ul>
          </div>
        </div>

        <div class="col-flex-row">
          <img class="illustration" src="img/icons/ic_category-marketing_strategy.svg" alt="" width="64" height="64" />
          <div>
            <h3>Strategy</h3>
            <ul class="services-list">
              <li>CONTENT STRATEGY</li>
              <li>SEO ROADMAP</li>
              <li><a href="/services/site-migrations">SITE MIGRATIONS ></a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>


  <section class="align-middle">
    <div class="ipu">
      <div>
        <p class="prehead">Our team</p>
        <h2>Powered by fresh <br />perspective.</h2>
        <p>Gray Dot Co is woman-owned, value-driven, and reimagining what it means to work with a digital marketing agency. Founded by a familiar face in the industry, we bring new ideas to the table as collaborators, not just consultants.</p>
        <a href="/team" class="btnPrimary">Get to know the Co</a>
      </div>
      <div class="add-margin-b">
        <img src={transformImageSrc("https://assets.thegray.company/f/1016570/500x375/53b5fa1d47/tory-017-1.png")} alt="Tory Gray headshot" />
      </div>
    </div>
  </section>


  {logoCarousel && <StoryblokComponent blok={logoCarousel} />}


  <section>
    <div class="ipu">
      <div>
        <img src="img/illustrations/il_gdc-8.png" width="480" height="280" alt="" />
      </div>

      <div class="size-two">
        <div class="add-margin-b">
          <p class="prehead">Our work</p>
          <h2>If you've got it, flaunt it.</h2>
        </div>

        <div class="col-flex-row">
          <a class="card-img-text" href="/resources/sb-nation-enterprise-migration-case-study">
            <img class="img-aspect" src={transformImageSrc("https://assets.thegray.company/f/1016570/900x600/e4c8cac48e/sbn-case-study-homepage-preview.png")} alt="SBNation and Gray Dot Co" width="450" height="293" />
