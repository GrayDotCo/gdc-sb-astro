  <section class="bg-grey">
    <div class="ipu">
      <div class="align-center">
        <p class="prehead">As featured on</p>
        <div class="flex-wrap margin-l logos">
          <img src="img/logos/logo_slate.svg" alt="Slate" title="Slate" width="500" height="255" />
          <img src="img/logos/logo_women-in-tech-seo.svg" alt="Women in Tech SEO" title="Women in Tech SEO" width="500" height="255" />
          <img src="img/logos/logo_oncrawl.svg" alt="Oncrawl" title="Oncrawl" width="500" height="255" />
          <img src="img/logos/logo_moz.svg" alt="MOZ" title="MOZ" width="500" height="255" />
          <img src="img/logos/logo_sitebulb.svg" alt="Sitebulb" title="Sitebulb" width="500" height="255" />
          <img src="https://assets.thegray.company/f/1016570/500x255/82dd883430/screamingfrog-logo-homepage.png" alt="ScreamingFrog" title="ScreamingFrog" width="500" height="255" />
          <img src="img/logos/logo_traffic-think-tank.svg" alt="Traffic Think Tank" title="Traffic Think Tank" width="500" height="255" />
          <img src="img/logos/logo_search-engine-land.svg" alt="Search Engine Land" title="Search Engine Land" width="500" height="255" />
          <img src="img/logos/logo_clearscope.svg" alt="Clearscope" title="Clearscope" width="500" height="255" />
        </div>
      </div>
    </div>
  </section>


  <section class="align-middle img-left">
    <div class="ipu">
      <div>
        <h2 class="title">Connect the dots with us.</h2>
        <p>We'll help craft, teach, and carry out SEO roadmaps that check all the boxes.</p>
        <a href="/contact" class="btnPrimary">TALK TO AN EXPERT</a>
      </div>
      <div>
        <img src="/img/illustrations/il_gdc-3.png" width="480" height="280" alt="decorative shapes" />
      </div>
    </div>
  </section>

